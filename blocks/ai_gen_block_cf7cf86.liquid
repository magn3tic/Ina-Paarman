{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .newsletters-archive-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .newsletters-archive__container-{{ ai_gen_id }} {
    max-width: 1350px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .newsletters-archive__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 48px;
  }

  .newsletters-archive__title-{{ ai_gen_id }} {
    font-family: 'Quarto', serif;
    font-size: {{ block.settings.heading_size }}rem;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .newsletters-archive__subtitle-{{ ai_gen_id }} {
    font-family: 'HelveticaNowText', sans-serif;
    font-size: 1rem;
    color: {{ block.settings.text_color }};
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Grid */
  .newsletters-archive__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* Card */
  .newsletters-archive__card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.10);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .newsletters-archive__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.10);
  }

  /* Image */
  .newsletters-archive__img-wrap-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 87.5%; /* 350/400 = 87.5% — prevents CLS */
    overflow: hidden;
    background: #f3f3f3;
  }

  .newsletters-archive__img-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .newsletters-archive__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f3f3;
  }

  .newsletters-archive__placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.2;
  }

  /* Card body */
  .newsletters-archive__body-{{ ai_gen_id }} {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  /* Title */
  .newsletters-archive__card-title-{{ ai_gen_id }} {
    font-family: 'Quarto', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #064956;
    margin: 0 0 10px;
    line-height: 1.35;
    text-transform: none;
    letter-spacing: 0;
  }

  /* Description */
  .newsletters-archive__card-desc-{{ ai_gen_id }} {
    font-family: 'HelveticaNowText', sans-serif;
    font-size: 0.9rem;
    color: #455a64;
    line-height: 1.65;
    margin: 0 0 20px;
    flex-grow: 1;
  }

  /* Button */
  .newsletters-archive__btn-wrap-{{ ai_gen_id }} {
    margin-top: auto;
  }

  .newsletters-archive__btn-wrap-{{ ai_gen_id }} .cta_btn.btn_border_default {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 11px 20px;
    font-family: 'HelveticaNowText', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease;
    text-decoration: none;
    box-sizing: border-box;
  }

  /* Responsive */
  @media (max-width: 991px) {
    .newsletters-archive__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
  }

  @media (max-width: 575px) {
    .newsletters-archive__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .newsletters-archive__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}rem * 0.75);
    }

    .newsletters-archive-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 | round }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 | round }}px;
    }
  }
{% endstyle %}

<section class="newsletters-archive-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="newsletters-archive__container-{{ ai_gen_id }}">

    {%- if block.settings.heading != blank or block.settings.description != blank -%}
      <div class="newsletters-archive__header-{{ ai_gen_id }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="newsletters-archive__title-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="newsletters-archive__subtitle-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="newsletters-archive__grid-{{ ai_gen_id }}">
      {%- for i in (1..12) -%}
        {%- liquid
          assign enabled_key     = 'card_' | append: i | append: '_enabled'
          assign image_key       = 'card_' | append: i | append: '_image'
          assign title_key       = 'card_' | append: i | append: '_title'
          assign desc_key        = 'card_' | append: i | append: '_description'
          assign btn_text_key    = 'card_' | append: i | append: '_button_text'
          assign btn_link_key    = 'card_' | append: i | append: '_button_link'

          assign card_enabled    = block.settings[enabled_key]
          assign card_image      = block.settings[image_key]
          assign card_title      = block.settings[title_key]
          assign card_desc       = block.settings[desc_key]
          assign card_btn_text   = block.settings[btn_text_key]
          assign card_btn_link   = block.settings[btn_link_key]
        -%}

        {%- if card_enabled -%}
          <article class="newsletters-archive__card-{{ ai_gen_id }}">

            {%- comment -%} Image — aspect-ratio wrapper prevents CLS {%- endcomment -%}
            <div class="newsletters-archive__img-wrap-{{ ai_gen_id }}">
              {%- if card_image != blank -%}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  srcset="
                    {{ card_image | image_url: width: 400 }} 400w,
                    {{ card_image | image_url: width: 800 }} 800w
                  "
                  sizes="(max-width: 575px) 100vw, (max-width: 991px) 50vw, 33vw"
                  alt="{{ card_image.alt | escape }}"
                  class="newsletters-archive__img-{{ ai_gen_id }} blog-box"
                  loading="lazy"
                  width="400"
                  height="350"
                >
              {%- else -%}
                <div class="newsletters-archive__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Card body {%- endcomment -%}
            <div class="newsletters-archive__body-{{ ai_gen_id }}">

              {%- if card_title != blank -%}
                <h4 class="newsletters-archive__card-title-{{ ai_gen_id }} h3">
                  <strong>{{ card_title }}</strong>
                </h4>
              {%- endif -%}

              {%- if card_desc != blank -%}
                <div class="newsletters-archive__card-desc-{{ ai_gen_id }}">
                  {{ card_desc }}
                </div>
              {%- endif -%}

              {%- if card_btn_text != blank and card_btn_link != blank -%}
                <div class="newsletters-archive__btn-wrap-{{ ai_gen_id }}">
                  <a href="{{ card_btn_link }}" class="cta_btn btn_border_default">
                    {{ card_btn_text | upcase }}
                  </a>
                </div>
              {%- endif -%}

            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

