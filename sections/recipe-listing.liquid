{% liquid
  if shop.permanent_domain contains 'ks-'
    assign limit = 6
  else
    assign limit = section.settings.limit
  endif
%}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js" defer></script>

<section class="recipe-filter banner-cta-area py-0">
  <div class="container">
    <div class="inner">
      <div class="select-wrap">

        {% if section.settings.mm_link %}
          <div class="select-container" id="select1">
            <div class="select-button">FILTER BY RECIPE CATEGORY</div>
            <ul class="options">
              {% for link in linklists[section.settings.mm_link].links %}
                <li>
                  {% assign link_handle = link.url | split: '/' | last %}
                  {% assign target_page = pages[link_handle] %}
                  {% if target_page and target_page.metafields.custom.recipe_type %}
                    <a href="{{ link.url }}" class="recipe-link"
                       data-handle="{{ link_handle }}"
                       data-recipetype="{{ target_page.metafields.custom.recipe_type | downcase }}">
                      {{ link.title }} <span id="total-posts-count-{{ link_handle }}"></span>
                    </a>
                  {% else %}
                    <p>No recipes found.</p>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {% if section.settings.mmm_link %}
          <div class="select-container" id="select2">
            <div class="select-button">FILTER BY OCCASION</div>
            <ul class="options">
              {% for link in linklists[section.settings.mmm_link].links %}
                <li>
                  {% assign link_handle = link.url | split: '/' | last %}
                  {% assign target_page = pages[link_handle] %}
                  {% if target_page and target_page.metafields.custom.recipe_type %}
                    <a href="{{ link.url }}" class="recipe-link"
                       data-handle="{{ link_handle }}"
                       data-recipetype="{{ target_page.metafields.custom.recipe_type | downcase }}">
                      {{ link.title }} <span id="total-posts-count-{{ link_handle }}"></span>
                    </a>
                  {% else %}
                    <p>No recipes found.</p>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

      </div>

      <div class="search-wrap-recipes">
        <form action="/search" method="get" class="search-form">
          <input
            type="text"
            name="q"
            placeholder="SEARCH"
            class="search-input"
            aria-label="Search"
            value="{{ search.terms }}"
          />
          <input type="hidden" name="type" value="article" />
          <button type="submit" class="search-button">
            <svg height="800px" version="1.1" viewBox="0 0 32 32" width="800px" xmlns="http://www.w3.org/2000/svg">
              <g fill="none" fill-rule="evenodd" stroke="none" stroke-width="1">
                <g fill="#000000" transform="translate(-256.000000, -1139.000000)">
                  <path d="M269.46,1163.45 C263.17,1163.45 258.071,1158.44 258.071,1152.25 C258.071,1146.06 263.17,1141.04 269.46,1141.04 C275.75,1141.04 280.85,1146.06 280.85,1152.25 C280.85,1158.44 275.75,1163.45 269.46,1163.45 L269.46,1163.45 Z M287.688,1169.25 L279.429,1161.12 C281.591,1158.77 282.92,1155.67 282.92,1152.25 C282.92,1144.93 276.894,1139 269.46,1139 C262.026,1139 256,1144.93 256,1152.25 C256,1159.56 262.026,1165.49 269.46,1165.49 C272.672,1165.49 275.618,1164.38 277.932,1162.53 L286.224,1170.69 C286.629,1171.09 287.284,1171.09 287.688,1170.69 C288.093,1170.3 288.093,1169.65 287.688,1169.25 L287.688,1169.25 Z"/>
                </g>
              </g>
            </svg>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const selectContainers = document.querySelectorAll('.select-container');

  selectContainers.forEach(container => {
    const button = container.querySelector('.select-button');
    button.addEventListener('click', () => {
      container.classList.toggle('open');
    });
  });

  document.addEventListener('click', (event) => {
    selectContainers.forEach(container => {
      if (!container.contains(event.target)) {
        container.classList.remove('open');
      }
    });
  });
</script>

<section class="content-area receipe_list pt-0">
  <div class="container">
    <div class="row justify-content-center">

      {% assign search_query = request.parameters.q | downcase | strip %}
      {% assign future_tagged = blog.articles | where: "tags", "Future" | map: "id" %}

      {% if search_query != blank %}

        {% comment %} Filter articles by search query against title {% endcomment %}
        {% assign matched_articles = '' %}
        {% assign match_count = 0 %}

        {% for article in blog.articles %}
          {% unless future_tagged contains article.id %}
            {% assign article_title_lower = article.title | downcase %}
            {% if article_title_lower contains search_query %}
              {% assign match_count = match_count | plus: 1 %}
              <div class="col-md-3 col-6">
                <a href="{{ article.url }}" class="recipe-box-alt">
                  {% if article.image %}
                    {{ article.image | image_url: width: 800 | image_tag: alt: article.title }}
                  {% else %}
                    <img src="https://cdn.shopify.com/s/files/1/0583/8415/4690/files/blog-thumbnail.jpg" alt="{{ article.title }}" width="800" height="800">
                  {% endif %}
                  <span class="d-block title">{{ article.title }}</span>
                </a>
              </div>
            {% endif %}
          {% endunless %}
        {% endfor %}

        {% if match_count == 0 %}
          <p>No recipes found for "{{ request.parameters.q }}".</p>
        {% endif %}

      {% else %}

        {% paginate blog.articles by limit %}
          {% if blog.articles.size == 0 %}
            <p>No Recipes</p>
          {% else %}
            {% for article in blog.articles %}
              {% unless future_tagged contains article.id %}
                <div class="col-md-3 col-6">
                  <a href="{{ article.url }}" class="recipe-box-alt">
                    {% if article.image %}
                      {{ article.image | image_url: width: 800 | image_tag: alt: article.title }}
                    {% else %}
                      <img src="https://cdn.shopify.com/s/files/1/0583/8415/4690/files/blog-thumbnail.jpg" alt="{{ article.title }}" width="800" height="800">
                    {% endif %}
                    <span class="d-block title">{{ article.title }}</span>
                  </a>
                </div>
              {% endunless %}
            {% endfor %}
            {% render 'pagination', paginate: paginate %}
          {% endif %}
        {% endpaginate %}

      {% endif %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Recipe Listing",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limit articles",
      "min": 1,
      "max": 50,
      "default": 6,
      "step": 1
    },
    {
      "type": "header",
      "content": "Filter"
    },
    {
      "type": "link_list",
      "id": "mm_link",
      "label": "Recipe Types"
    },
    {
      "type": "link_list",
      "id": "mmm_link",
      "label": "Occasion"
    }
  ],
  "presets": [
    {
      "name": "Recipe Listing"
    }
  ]
}
{% endschema %}