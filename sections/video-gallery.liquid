<section class="video-gallery pt-3">
  <div class="container">

    {% if section.settings.heading != blank %}
    <div class="row">
      <div class="col-12 text-start mb-4">
          <h3><b>{{ section.settings.heading }}</b></h3>
        </div>
      </div>
    {% endif %}

    {% if section.settings.enable_filter %}
      {% assign all_filters = '' %}

      {% for block in section.blocks %}
        {% assign block_filters = block.settings.filters | split: ',' %}
        {% for f in block_filters %}
          {% assign f_clean = f | strip %}
          {% unless all_filters contains f_clean %}
            {% assign all_filters = all_filters | append: f_clean | append: ',' %}
          {% endunless %}
        {% endfor %}
      {% endfor %}

      {% assign filter_array = all_filters | split: ',' %}

      <div class="row mb-4">
        <div class="col-md-5 col-lg-4 mx-auto">
          <select class="form-select video-filter">
            {% for f in filter_array %}
              {% if f != blank %}
                <option value="{{ f | handle }}" {% if forloop.first %}selected{% endif %}>
                  {{ f }}
                </option>
              {% endif %}
            {% endfor %}
          </select>
        </div>
      </div>
    {% endif %}   
  
    <div class="row align-items-end">
        {% assign block_count = 0 %}
        {% for block in section.blocks %}
        
          {% if section.settings.sub_heading != blank %}
              <span class="d-block sub_heading">{{ section.settings.sub_heading }}</span>
            {% endif %}

{% assign filters = block.settings.filters | split: ',' %}
{% assign filter_handles = '' %}

{% for f in filters %}
  {% assign filter_handles = filter_handles | append: f | strip | handle | append: ' ' %}
{% endfor %}

<div class="col-sm-6 col-md-4 mb-4 video-item {% if section.settings.enable_filter %}video-filter-item{% endif %}"
     {% if section.settings.enable_filter %}
     data-filter="{{ filter_handles }}"
     {% endif %}>

              {% assign youtube_id = block.settings.youtube_id %}
              {% if block.settings.sub_heading != blank %}
                <h3 class="h4 text-start mt-2">{{ block.settings.sub_heading }}</h3>
              {% endif %}
              <div class="ratio ratio-16x9">
                <iframe
                  src="https://www.youtube.com/embed/{{ youtube_id }}?rel=0"
                  frameborder="0"
                  allowfullscreen>
                </iframe>
              </div>

              <a href="https://www.youtube.com/watch?v={{ youtube_id }}" target="_blank" class="text-start small text-secondary my-2 d-block">
                View full instructions on YouTube
              </a>
            </div>
        {% endfor %}
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const filterSelect = document.querySelector(".video-filter");
  if (!filterSelect) return;

  const items = document.querySelectorAll(".video-filter-item");

  filterSelect.addEventListener("change", function () {
    const value = this.value;

    items.forEach(item => {
      if (value === "all") {
        item.style.display = "block";
      } else {
        if (item.dataset.filter.includes(value)) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      }
    });
  });

});
</script>

{% schema %}
{
  "name": "Video Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "enable_filter",
      "label": "Enable Filter",
      "default": false
    }    
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
      "type": "text",
      "id": "sub_heading",
      "label": "Video Title",
      },
      {
        "type": "text",
        "id": "youtube_id",
        "label": "YouTube Video ID",
        "info": "Enter the unique YouTube video ID (e.g., dQw4w9WgXcQ)"
      },
      {
          "type": "text",
          "id": "filters",
          "label": "Filters (comma separated for multiple)",
          "info": "Example: Engine, Setup, Maintenance"
        }      
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Gallery",
      "category": "Custom"
    }
  ]
}
{% endschema %}