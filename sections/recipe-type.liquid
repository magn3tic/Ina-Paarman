                  </li>
                {% endfor %}
              </ul>
            </div>
          
            <script>
              $(document).ready(function() {
                $('.recipe-link').each(function() {
                  var linkHandle = $(this).data('handle');  
                  var recipetype = $(this).data('recipetype'); 
          
                  var formattedRecipetype = recipetype
                    .toLowerCase()                         
