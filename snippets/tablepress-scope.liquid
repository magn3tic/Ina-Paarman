{% comment %}
  TablePress (IdentixWeb) performance scoping
  --------------------------------------------
  The app's embed loader skips fetching tablepress.bundle.js (~399KB)
  when a global `specificBunLoad` variable is already defined, and skips
  injecting tablepress.css (~29KB) when an element with id "tablepressCss"
  already exists. This snippet uses both hooks to suppress TablePress on
  templates that never contain tables.

  Design: BLOCKLIST. We only suppress on known table-free, high-traffic
  templates. All regular pages (template.name == 'page') are left alone,
  so if a table is ever added to a new page it works with no code change.

  Include from theme.liquid inside <head>:  {% render 'tablepress-scope' %}
{% endcomment %}

{%- liquid
  assign block_tablepress = false

  case template.name
    when 'index', 'collection', 'list-collections', 'blog', 'article', 'search', 'cart', '404', 'password'
      assign block_tablepress = true
    when 'product'
      if product.metafields.custom.tablepress == blank
        assign block_tablepress = true
      endif
  endcase
-%}

{%- if block_tablepress -%}
  <script>var specificBunLoad = true;</script>
  <style id="tablepressCss"></style>
{%- endif -%}
